---
const { rank, title, artist, streams } = Astro.props;

const colors = [
  '#ffd6e0', '#d6f5e3', '#d6e8ff', '#fff3d6', '#f0d6ff',
  '#ffe8d6', '#d6fff8', '#ffd6f5', '#e8ffd6', '#d6f0ff',
];

const color = colors[(rank - 1) % colors.length];
---

<article class="card" style={`background: ${color};`}>
  <span class="rank">#{rank}</span>
  <h3>{title}</h3>
  <p class="artist">{artist}</p>
  <p class="streams">{streams} reproducciones</p>
</article>

<style>
  .card {
    border-radius: 10px;
    padding: 1.2rem;
    transition: transform 0.2s;
    cursor: pointer;
  }
  .card:hover {
    transform: translateY(-4px);
  }
  .rank {
    font-size: 0.8rem;
    font-weight: 700;
    color: #555;
  }
  h3 {
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-top: 6px;
  }
  .artist {
    color: #666;
    font-size: 0.85rem;
    margin-top: 3px;
  }
  .streams {
    font-size: 0.75rem;
    margin-top: 8px;
    color: #888;
  }
</style>